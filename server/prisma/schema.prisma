generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  TRAINER
  ADMIN
}

enum MembershipPlan {
  INTRO
  PLUS
  PREMIUM
  MAX
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum ClassType {
  YOGA
  STRENGTH
  CARDIO
  MMA
  HIIT
  ZUMBA
  BARRE
  PERSONAL_TRAINING
  NUTRITION
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  phone         String?
  passwordHash  String
  role          Role      @default(MEMBER)
  avatarUrl     String?
  dateOfBirth   DateTime?
  gender        String?
  address       String?
  emergencyContact String?
  refreshToken  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   Membership[]
  payments      Payment[]
  workouts      Workout[]
  measurements  Measurement[]
  bookings      Booking[]
  attendance    Attendance[]
  notifications Notification[]
  trainedClasses GymClass[] @relation("TrainerClasses")
  progressPhotos ProgressPhoto[]
  contactForms  ContactForm[]
}

model Membership {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  plan      MembershipPlan
  status    MembershipStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime
  price     Float
  paymentId String?
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  razorpayOrderId String?       @unique
  razorpayPaymentId String?
  amount          Float
  plan            MembershipPlan
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model GymClass {
  id          String    @id @default(cuid())
  name        String
  type        ClassType
  trainerId   String
  trainer     User      @relation("TrainerClasses", fields: [trainerId], references: [id])
  startTime   DateTime
  endTime     DateTime
  capacity    Int       @default(20)
  location    String    @default("Main Floor")
  description String?
  isRecurring Boolean   @default(false)
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookings    Booking[]
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  classId   String
  class     GymClass      @relation(fields: [classId], references: [id])
  status    BookingStatus @default(CONFIRMED)
  bookedAt  DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, classId])
}

model Attendance {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  checkedInAt DateTime @default(now())
  classId     String?
  notes       String?
}

model Workout {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  date      DateTime
  notes     String?
  duration  Int?
  exercises WorkoutExercise[]
  createdAt DateTime        @default(now())
}

model WorkoutExercise {
  id         String  @id @default(cuid())
  workoutId  String
  workout    Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name       String
  sets       Int
  reps       Int
  weightKg   Float?
  notes      String?
  order      Int     @default(0)
}

model Measurement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime
  weightKg    Float?
  bodyFatPct  Float?
  chestCm     Float?
  waistCm     Float?
  hipsCm      Float?
  bicepCm     Float?
  notes       String?
  createdAt   DateTime @default(now())
}

model ProgressPhoto {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  imageUrl    String
  cloudinaryId String?
  takenAt     DateTime
  notes       String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model ContactForm {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  email     String
  phone     String?
  interest  String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

